# Supabase Postgres
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres?schema=public"

# Auth.js
AUTH_SECRET="replace-with-generated-auth-secret"
AUTH_GOOGLE_ID="replace-with-google-oauth-client-id"
AUTH_GOOGLE_SECRET="replace-with-google-oauth-client-secret"
AUTH_GITHUB_ID="replace-with-github-oauth-client-id"
AUTH_GITHUB_SECRET="replace-with-github-oauth-client-secret"

# OpenAI
OPENAI_API_KEY="replace-with-openai-api-key"

# Upstash Redis / QStash
UPSTASH_REDIS_REST_URL="https://example.upstash.io"
UPSTASH_REDIS_REST_TOKEN="replace-with-upstash-redis-rest-token"
QSTASH_TOKEN="replace-with-qstash-token"
QSTASH_CURRENT_SIGNING_KEY="replace-with-current-signing-key"
QSTASH_NEXT_SIGNING_KEY="replace-with-next-signing-key"

# Cloudflare R2
CF_ACCOUNT_ID="replace-with-cloudflare-account-id"
CF_ACCESS_KEY_ID="replace-with-r2-access-key-id"
CF_SECRET_ACCESS_KEY="replace-with-r2-secret-access-key"
CF_R2_BUCKET="replace-with-r2-bucket-name"

# Resend
RESEND_API_KEY="replace-with-resend-api-key"

NEXT_PUBLIC_APP_URL="http://localhost:3000"
